rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Helper functions ─────────────────────────────────────────────
    function isEmailVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── User Profiles ────────────────────────────────────────────────
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;

      // Diary subcollection (daily entries)
      match /diary/{dateId} {
        allow read, write: if isEmailVerified() && isOwner(userId);
      }

      // Planner subcollection (semester data, schedule, generated plan)
      match /planner/{docId} {
        allow read, write: if isEmailVerified() && isOwner(userId);
      }
    }

    // ── Global Collections (Owned by userId) ─────────────────────────
    // Subjects, Topics, Tasks, SchedulerTasks, PersonalGoals, GoalTasks
    
    match /{collectionName}/{docId} {
      allow read, update, delete: if collectionName in [
        'subjects', 'topics', 'tasks', 'schedulerTasks', 'personalGoals', 'goalTasks'
      ] && isEmailVerified() && resource.data.userId == request.auth.uid;

      allow create: if collectionName in [
        'subjects', 'topics', 'tasks', 'schedulerTasks', 'personalGoals', 'goalTasks'
      ] && isEmailVerified() && request.resource.data.userId == request.auth.uid;
    }

    // ── Security Logs (Audit Trail) ──────────────────────────────────
    match /securityLogs/{logId} {
      // Allow authenticated users to create logs (but never read/edit/delete)
      // This ensures an immutable trail of events.
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
